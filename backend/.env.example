PORT=
DATABASE_URL=
JWT_SECRET=

# SMTP (Nodemailer) — transactional mail (signup OTP, completion invoice to customers, etc.)
# Examples: Mailpit/MailHog (localhost), Gmail (smtp.gmail.com), SendGrid, SES SMTP, etc.
SMTP_HOST=
SMTP_PORT=587
# Use true for port 465 (SSL); false for 587/25 (STARTTLS)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Display name + address shown as From (must be allowed by your provider)
SMTP_FROM=Mobile Mechanic <noreply@example.com>
# Alias supported by config; SMTP_FROM takes precedence
# EMAIL_FROM=

OTP_TTL_MINUTES=10
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# -----------------------------------------------------------------------------
# Twilio Verify (SMS) — required for production signup unless you use dev skip below
# Create a Verify Service: Twilio Console → Verify → Services → Create
# Trial accounts can only SMS to verified numbers (Console → Phone Numbers → Verified Caller IDs)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
# ISO country when users omit +country (e.g. IN for India)
DEFAULT_PHONE_REGION=IN
# Non-production only: set true to skip real SMS (accept any 4–8 digit SMS code). Never in production.
PHONE_VERIFY_SKIP=

# -----------------------------------------------------------------------------
# Web Push (VAPID) — browser notifications for bookings
# -----------------------------------------------------------------------------
# Without keys, GET /api/push/vapid-public-key returns null and the UI will not
# subscribe. The server will not send pushes (sendToUser / notifyMechanicsNearby).
#
# Quick setup:
#   1. Apply DB migration (from backend/: npm run db:migrate-push — reads DATABASE_URL from .env)
#   2. From backend/: npm run generate-vapid
#   3. Paste the two lines below into backend/.env (real values, no quotes)
#   4. Restart the API
#
# Full guide: backend/PUSH_NOTIFICATIONS.md
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Cloudinary — images (profile photo, booking vehicle photos)
# When set, uploads use Cloudinary; otherwise files are stored under backend/uploads (local dev).
# Dashboard: https://cloudinary.com/console — copy API Environment variable as CLOUDINARY_URL
# Or set the three values below.
# -----------------------------------------------------------------------------
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -----------------------------------------------------------------------------
# Groq — AI triage (suggested service category from problem description)
# Dashboard: https://console.groq.com/keys — create a key and set:
# GROQ_API_KEY=gsk_...
# Optional model (default: llama-3.1-8b-instant)
# GROQ_MODEL=llama-3.1-8b-instant
# -----------------------------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=

# -----------------------------------------------------------------------------
# Razorpay — INR payments (Test/Live keys from https://dashboard.razorpay.com/)
# Key ID is safe to expose to the frontend; Key Secret must stay server-only.
# Run: npm run db:migrate-razorpay
# Run: npm run db:migrate-payment-method
# -----------------------------------------------------------------------------
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
