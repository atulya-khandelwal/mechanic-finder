# Default country when users type a local number without +country (must match backend DEFAULT_PHONE_REGION)
VITE_DEFAULT_PHONE_REGION=IN

# Mapbox access token - get one at https://account.mapbox.com/
# Required for map display, address search, and location tracking
VITE_MAPBOX_ACCESS_TOKEN=

# Web Push / VAPID: no variable needed here. The app fetches the public key from
# the backend (GET /api/push/vapid-public-key). Configure VAPID_* in backend/.env.